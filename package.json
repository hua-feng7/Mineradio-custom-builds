{
  "name": "mineradio",
  "productName": "Mineradio",
  "version": "1.1.1",
  "description": "沉浸式音乐播放器，融合天气电台、歌词舞台、粒子视觉和 3D 歌单架。",
  "author": "Mineradio",
  "main": "desktop/main.js",
  "packageManager": "pnpm@11.7.0",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --publish never",
    "build:mac:apple": "electron-builder --mac dmg zip --arm64 --publish never",
    "build:mac:dir": "electron-builder --mac dir --arm64 --publish never",
    "build:win": "electron-builder --win nsis --publish never",
    "build:win:dir": "electron-builder --win dir --publish never"
  },
  "build": {
    "appId": "com.mineradio.desktop",
    "productName": "Mineradio",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "build/**/*",
      "server.js",
      "dj-analyzer.js",
      "package.json",
      "!public/index.*.html",
      "public/index.html"
    ],
    "asar": false,
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.music",
      "type": "development",
      "identity": "-",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "notarize": false,
      "minimumSystemVersion": "11.0",
      "electronLanguages": [
        "zh-CN",
        "en"
      ],
      "extendInfo": {
        "LSMinimumSystemVersion": "11.0",
        "LSRequiresNativeExecution": true,
        "NSHighResolutionCapable": true,
        "NSSupportsAutomaticGraphicsSwitching": true,
        "LSApplicationCategoryType": "public.app-category.music",
        "NSMicrophoneUsageDescription": "Mineradio 使用麦克风进行节奏分析和可视化。",
        "NSCameraUsageDescription": "Mineradio 使用相机进行视觉交互。"
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "Mineradio-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "title": "Mineradio ${version}",
      "icon": "build/icon.png",
      "iconSize": 80,
      "window": {
        "width": 500,
        "height": 380
      }
    },
    "win": {
      "executableName": "Mineradio",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mineradio",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "artifactName": "Mineradio-${version}-Setup.${ext}"
    }
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "NeteaseCloudMusicApi": "^4.32.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "rcedit": "^5.0.2"
  }
}
